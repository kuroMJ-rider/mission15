                 0.29  \n","2                         0.04  \n","3                         0.23  \n","4                         0.53  \n"]}]},{"cell_type":"code","source":["from sklearn.metrics import silhouette_score\n","\n","score_kmeans = silhouette_score(X_scaled, data['cluster5'])\n","score_hier = silhouette_score(X_scaled, data['hier_cluster'])\n","\n","print(f'K-means:  {score_kmeans:.4f}')\n","print(f'계층적:   {score_hier:.4f}')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"1OzEhp5PixhI","executionInfo":{"status":"ok","timestamp":1774160051468,"user_tz":-540,"elapsed":3248,"user":{"displayName":"Mijeong Jeon","userId":"07313534631694111325"}},"outputId":"12a8ace1-1363-4135-86d2-91667f171054"},"execution_count":42,"outputs":[{"output_type":"stream","name":"stdout","text":["K-means:  0.1932\n","계층적:   0.1361\n"]}]},{"cell_type":"markdown","source":["### 계층적 클러스터링 결과\n","- 덴드로그램은 Mission14에서 전체 데이터로 돌렸을 때 너무 복잡해서 이번에는 샘플링(500개) 후 모델링하기로 했습니다.\n","- 맨 아래부터 봤을 때 주황이 가장 큰 덩어리, 파랑이 그 다음, 빨강과 보라가 소규모 군집, 초록이 가장 작았습니다.\n","- 덴드로그램은 bottom up 방식이라고 배웠고, 위로 올라갈 수록 유사한 것들끼리 합쳐지는데, 이 데이터의 덴드로그램을 읽어보면 distance 47에서 53에 도달할 즈음 4~5개의 군집으로 묶입니다. K-means의 k=5처럼 덴드로그램에서도 그 값이 지지된다고 생각합니다.\n","- 실루엣 스코어를 비교해보니 K-means보다 더 낮은 점수가 나왔습니다. 단 hier-cluster 4는 그 기술통계량으로 특성을 봤을 때 K-means의 1번 클러스터와 동질 그룹으로 보입니다. 이를 고려하면 계층적 클러스터링에서 VVIP 그룹을 86명에서 23명으로 더 추려낸 것으로 보입니다."],"metadata":{"id":"YqsBc8YIjIwT"}},{"cell_type":"markdown","source":["### Mission14 연계 진행\n","- 4개 알고리즘을 비교한 결과 Mission 14, 15의 데이터는 K-means와 게층적 클러스터링이 종합 평가에서 DBSCAN, GMM 대비 좋은 성과를 보였습니다.\n","- 이는 데이터의 밀도가 균일하지 않고 극단값이 많은 데이터의 특성 때문입니다. Mission 14에서 DBSCAN을 진행할 때 eps값을 여러 차례 조정했지만 클러스터 쏠림 현상이 너무 심했고, 세분화가 잘 되지 않았습니다. GMM의 경우는 균등하게 3개 그룹으로 나눴지만 대부분의 고객이 1.0 대 0.0으로 나뉘어 성능이 떨어졌습니다.\n","- 고객의 소비 패턴에 따라 의미 있는 군집으로 분류하라는 미션 정의에 충실하기 위해 가장 적합한 알고리즘으로 정한 K-means와 계층적 클러스터링까지 진행하는 것으로 하고, PCA로 차원 축소까지 진행 후 군집별 고객 유형을 해석하겠습니다."],"metadata":{"id":"_Cl2IFXMmgAK"}},{"cell_type":"markdown","source":["## PCA 주성분 분석"],"metadata":{"id":"zKXTLAA9mP_g"}},{"cell_type":"code","source":["# PCA 2D 시각화용\n","from sklearn.decomposition import PCA\n","\n","pca = PCA(n_components=2)\n","pca_result = pca.fit_transform(X_scaled)\n","\n","print(f'PC1: {pca.explained_variance_ratio_[0]*100:.1f}%')\n","print(f'PC2: {pca.explained_variance_ratio_[1]*100:.1f}%')\n","print(f'합계: {pca.explained_variance_ratio_.sum()*100:.1f}%')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"PG0m5NiwjRKz","executionInfo":{"status":"ok","timestamp":1774160051477,"user_tz":-540,"elapsed":7,"user":{"displayName":"Mijeong Jeon","userId":"07313534631694111325"}},"outputId":"2d47ad5d-5f83-44ae-d27a-85ff6a7e1b43"},"execution_count":43,"outputs":[{"output_type":"stream","name":"stdout","text":["PC1: 27.3%\n","PC2: 20.3%\n","합계: 47.6%\n"]}]},{"cell_type":"code","source":["# 적절한 주성분 수 결정\n","pca_full = PCA(n_components=17)\n","pca_full.fit(X_scaled)\n","\n","cumsum = np.cumsum(pca_full.explained_variance_ratio_)\n","\n","# 75%, 90% 기준 주성분 수\n","n_75 = next(i+1 for i, v in enumerate(cumsum) if v >= 0.75)\n","n_90 = next(i+1 for i, v in enumerate(cumsum) if v >= 0.90)\n","print(f'75% 설명: {n_75}개')\n","print(f'90% 설명: {n_90}개')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"dqwv8jBOomOa","executionInfo":{"status":"ok","timestamp":1774160051484,"user_tz":-540,"elapsed":6,"user":{"displayName":"Mijeong Jeon","userId":"07313534631694111325"}},"outputId":"0fadece5-8030-4887-8a7c-999c363196ec"},"execution_count":44,"outputs":[{"output_type":"stream","name":"stdout","text":["75% 설명: 6개\n","90% 설명: 10개\n"]}]},{"cell_type":"code","source":["# 클러스터링용 PCA 6개\n","pca6 = PCA(n_components=6)\n","pca6_result = pca6.fit_transform(X_scaled)\n","\n","pca6_df = pd.DataFrame(pca6_result, columns=[f'PC{i+1}' for i in range(6)])\n","\n","print(f'설명된 분산: {pca6.explained_variance_ratio_.sum()*100:.1f}%')\n","print(pca6_df.shape)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"p2Tsv3_yo1i4","e